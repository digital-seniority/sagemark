{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_GIT_COMMIT_SHA"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "SEO_SERVICE_URL",
        "IMAGEGEN_SERVICE_URL",
        "VIDEOGEN_SERVICE_URL",
        "PPC_SERVICE_URL",
        "INTELLIGENCE_SERVICE_URL",
        "ANTHROPIC_API_KEY",
        "AI_GATEWAY_API_KEY",
        "AI_GATEWAY_BASE_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["DATABASE_URL", "RLS_TEST_PG_CONTAINER"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
